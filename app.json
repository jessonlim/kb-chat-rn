{
  "expo": {
    "name": "KB Chat",
    "slug": "kb-chat-rn",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "scheme": "kbchat",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3fb0c9bb-a5d1-421b-adb3-aaf3e87689c1",
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#dc2626"
    },
    "plugins": [
      "@livekit/react-native-expo-plugin",
      "expo-dev-client",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "KB Chat needs camera access to scan QR codes and make video calls"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "KB Chat needs location access to share your location in chats"
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "KB Chat needs access to your contacts to help you find friends who already use the app."
        }
      ],
      [
        "react-native-full-screen-notification-incoming-call",
        {
          "statusBarColor": "#000000"
        }
      ],
      "@sentry/react-native",
      "expo-secure-store",
      "expo-callkit-telecom",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      "./plugins/withNotifeeForegroundServiceType"
    ],
    "ios": {
      "bundleIdentifier": "com.kbchat.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "KB Chat needs camera access to scan QR codes and make video calls",
        "NSMicrophoneUsageDescription": "KB Chat needs microphone access for voice and video calls",
        "NSLocationWhenInUseUsageDescription": "KB Chat needs location access to share your location in chats",
        "NSContactsUsageDescription": "KB Chat needs access to your contacts to help you find friends who already use the app.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bitcode": false
    },
    "android": {
      "package": "com.kbchat.app",
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_PHONE_CALL",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.FOREGROUND_SERVICE_CAMERA",
        "android.permission.VIBRATE",
        "android.permission.DISABLE_KEYGUARD",
        "android.permission.MANAGE_OWN_CALLS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CALL_PHONE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#dc2626"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "https",
              "host": "kb-chat.com",
              "pathPrefix": "/u/"
            },
            {
              "scheme": "https",
              "host": "www.kb-chat.com",
              "pathPrefix": "/u/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#dc2626",
      "androidMode": "default"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "3fb0c9bb-a5d1-421b-adb3-aaf3e87689c1"
      }
    },
    "owner": "meka-games"
  }
}
