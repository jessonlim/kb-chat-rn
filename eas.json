{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "// appleId": "Apple ID email — eas-cli will prompt + save on first run",
        "// ascAppId": "App Store Connect App ID — from appstoreconnect.apple.com after creating the app",
        "// appleTeamId": "Apple Developer Team ID — from developer.apple.com membership page"
      }
    }
  }
}
